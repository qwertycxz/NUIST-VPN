{
	"manifest_version": 3,
	"name": "NUIST VPN",
	"version": "0.1.9",
	"description": "一键通过校园VPN访问网页",
	"icons": {
		"16": "icon.png",
		"48": "icon.png",
		"128": "icon.png"
	},
	"action": {
		"default_icon": "icon.png"
	},
	"background": {
		"service_worker": "bg.js"
	},
	"options_page": "options.html",
	"homepage_url": "https://qwertycxz.top",
	"incognito": "split",
	"content_security_policy": {
		"extension_pages": "script-src 'self'; object-src 'self'"
	},
	"permissions": [
		"activeTab",
		"scripting",
		"storage",
		"notifications"
	]

}
